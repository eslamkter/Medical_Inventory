<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_consumption_request_form" model="ir.ui.view">
        <field name="name">medical.consumption.request.form</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <form string="Consumption Request">
                <header>
                    <button name="action_submit" string="Submit Request"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            groups="base.group_system"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            groups="base.group_system"
                            invisible="state != 'submitted'"/>
                    <button name="action_process_stock" string="Process &amp; Move Stock"
                            type="object" class="btn-primary"
                            groups="base.group_system"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ['done', 'cancelled']"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ['cancelled', 'rejected']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="date_request" readonly="state != 'draft'"/>
                            <field name="requested_by" readonly="state != 'draft'"/>
                            <field name="department_location_id" readonly="state != 'draft'"/>
                            <field name="source_location_id" readonly="state != 'draft'"/>
                        </group>
                        <group string="Approval Info">
                            <field name="approved_by" readonly="1"/>
                            <field name="date_approved" readonly="1"/>
                            <field name="stock_picking_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items Requested">
                            <field name="line_ids" readonly="state not in ['draft']">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="lot_id"/>
                                    <field name="expiry_date" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    <field name="available_qty" optional="show"/>
                                    <field name="notes" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" readonly="state != 'draft'"
                                   placeholder="Reason for request, urgency, etc."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_consumption_request_list" model="ir.ui.view">
        <field name="name">medical.consumption.request.list</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <list string="Consumption Requests" decoration-success="state == 'done'"
                  decoration-warning="state == 'submitted'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="date_request"/>
                <field name="requested_by"/>
                <field name="department_location_id"/>
                <field name="source_location_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'submitted'"
                       decoration-info="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_consumption_request_search" model="ir.ui.view">
        <field name="name">medical.consumption.request.search</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <search string="Search Requests">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="department_location_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Awaiting Approval" name="submitted" domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <separator/>
                <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Department" name="group_dept" context="{'group_by': 'department_location_id'}"/>
                <filter string="Requested By" name="group_user" context="{'group_by': 'requested_by'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_consumption_request" model="ir.actions.act_window">
        <field name="name">Consumption Requests</field>
        <field name="res_model">medical.consumption.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_consumption_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first consumption request
            </p>
            <p>
                Use consumption requests to move stock out of the main store
                to a clinic or department — without creating a sale or invoice.
            </p>
        </field>
    </record>


    <!-- Expiry Tracker using our own data -->
    <record id="view_expiry_tracker_list" model="ir.ui.view">
        <field name="name">medical.expiry.tracker.list</field>
        <field name="model">medical.consumption.request.line</field>
        <field name="arch" type="xml">
            <list string="Expiry Tracker">
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="expiry_date"/>
                <field name="request_id"/>
            </list>
        </field>
    </record>

    <record id="action_expiry_tracker" model="ir.actions.act_window">
        <field name="name">Expiry Tracker</field>
        <field name="res_model">medical.consumption.request.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_expiry_tracker_list"/>
        <field name="domain">[('expiry_date', '!=', False)]</field>
    </record>


</odoo>
