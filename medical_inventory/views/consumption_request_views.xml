<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== نموذج طلب النقل ===== -->
    <record id="view_transfer_request_form" model="ir.ui.view">
        <field name="name">medical.transfer.request.form</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <form string="طلب نقل المخزون">
                <header>
                    <button name="action_submit" string="تقديم الطلب"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="موافقة"
                            type="object" class="btn-success"
                            groups="base.group_system"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="رفض"
                            type="object" groups="base.group_system"
                            invisible="state != 'submitted'"/>
                    <button name="action_process_stock"
                            string="معالجة ونقل المخزون"
                            type="object" class="btn-primary"
                            groups="base.group_system"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" string="إلغاء" type="object"
                            invisible="state in ['done','cancelled']"/>
                    <button name="action_reset_draft" string="إعادة إلى المسودة"
                            type="object"
                            invisible="state not in ['cancelled','rejected']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="تفاصيل الطلب">
                            <field name="request_type" invisible="1"/>
                            <field name="date_request" readonly="state != 'draft'" string="تاريخ الطلب"/>
                            <field name="requested_by" readonly="state != 'draft'" string="طُلب بواسطة"/>
                            <field name="department_location_id"
                                   string="التسليم إلى (العيادة)"
                                   readonly="state != 'draft'"/>
                            <field name="source_location_id"
                                   string="الأخذ من (المستودع)"
                                   required="1"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="معلومات الموافقة">
                            <field name="approved_by" readonly="1" string="معتمد من قبل"/>
                            <field name="date_approved" readonly="1" string="تاريخ الموافقة"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="العناصر المطلوبة">
                            <field name="line_ids" readonly="state not in ['draft']">
                                <list editable="bottom">
                                    <field name="product_id" string="المنتج"/>
                                    <field name="quantity" string="الكمية"/>
                                    <field name="product_uom_id" string="الوحدة"/>
                                    <field name="available_qty"
                                           string="متاح في المستودع" readonly="1"/>
                                    <field name="notes" optional="show" string="ملاحظات"/>
                                </list>
                            </field>
                        </page>
                        <page string="الملاحظات">
                            <field name="notes" readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_transfer_request_list" model="ir.ui.view">
        <field name="name">medical.transfer.request.list</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <list string="طلبات النقل"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'cancelled'">
                <field name="name" string="المرجع"/>
                <field name="date_request" string="التاريخ"/>
                <field name="requested_by" string="طُلب بواسطة"/>
                <field name="department_location_id" string="التسليم إلى"/>
                <field name="source_location_id" string="الأخذ من"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state in ['rejected','cancelled']"/>
            </list>
        </field>
    </record>

    <record id="action_transfer_request" model="ir.actions.act_window">
        <field name="name">طلبات النقل</field>
        <field name="res_model">medical.consumption.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('request_type','=','transfer')]</field>
        <field name="context">{'default_request_type': 'transfer'}</field>
    </record>

    <!-- ===== نموذج تقرير الاستهلاك ===== -->
    <record id="view_consumption_request_form" model="ir.ui.view">
        <field name="name">medical.consumption.request.form</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <form string="تقرير الاستهلاك">
                <header>
                    <button name="action_submit" string="تقديم التقرير"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="موافقة"
                            type="object" class="btn-success"
                            groups="base.group_system"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="رفض"
                            type="object" groups="base.group_system"
                            invisible="state != 'submitted'"/>
                    <button name="action_process_stock"
                            string="تأكيد الاستهلاك وتخفيض المخزون"
                            type="object" class="btn-primary"
                            groups="base.group_system"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" string="إلغاء" type="object"
                            invisible="state in ['done','cancelled']"/>
                    <button name="action_reset_draft" string="إعادة إلى المسودة"
                            type="object"
                            invisible="state not in ['cancelled','rejected']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="تفاصيل الطلب">
                            <field name="request_type" invisible="1"/>
                            <field name="date_request" readonly="state != 'draft'" string="تاريخ الطلب"/>
                            <field name="requested_by" readonly="state != 'draft'" string="طُلب بواسطة"/>
                            <field name="department_location_id"
                                   string="العيادة / القسم"
                                   readonly="state != 'draft'"/>
                            <field name="source_location_id"
                                   string="الأخذ من (المستودع)"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="معلومات الموافقة">
                            <field name="approved_by" readonly="1" string="معتمد من قبل"/>
                            <field name="date_approved" readonly="1" string="تاريخ الموافقة"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="العناصر المستهلكة">
                            <field name="line_ids" readonly="state not in ['draft']">
                                <list editable="bottom">
                                    <field name="product_id" string="المنتج"/>
                                    <field name="quantity" string="الكمية"/>
                                    <field name="product_uom_id" string="الوحدة"/>
                                    <field name="available_qty"
                                           string="متاح في العيادة" readonly="1"/>
                                    <field name="notes" optional="show" string="ملاحظات"/>
                                </list>
                            </field>
                        </page>
                        <page string="الملاحظات">
                            <field name="notes" readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_consumption_request_list" model="ir.ui.view">
        <field name="name">medical.consumption.request.list</field>
        <field name="model">medical.consumption.request</field>
        <field name="arch" type="xml">
            <list string="تقارير الاستهلاك"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'cancelled'">
                <field name="name" string="المرجع"/>
                <field name="date_request" string="التاريخ"/>
                <field name="requested_by" string="طُلب بواسطة"/>
                <field name="department_location_id" string="العيادة"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state in ['rejected','cancelled']"/>
            </list>
        </field>
    </record>

    <record id="action_consumption_request" model="ir.actions.act_window">
        <field name="name">تقارير الاستهلاك</field>
        <field name="res_model">medical.consumption.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('request_type','=','consumption')]</field>
        <field name="context">{'default_request_type': 'consumption'}</field>
    </record>

</odoo>
