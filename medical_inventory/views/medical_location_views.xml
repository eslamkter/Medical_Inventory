<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_medical_location_form" model="ir.ui.view">
        <field name="name">medical.location.form</field>
        <field name="model">medical.location</field>
        <field name="arch" type="xml">
            <form string="العيادة / القسم">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_stock" type="object"
                                class="oe_stat_button" icon="fa-cubes"
                                invisible="not location_id">
                            <field name="current_stock_count" widget="statinfo"
                                   string="المنتجات في المخزون"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="مثال: عيادة 4"/></h1>
                    </div>
                    <group>
                        <group string="التفاصيل">
                            <field name="location_type" string="النوع"/>
                            <field name="responsible_id" string="المسؤول"/>
                            <field name="active" string="نشط"/>
                        </group>
                        <group string="الموقع المرتبط">
                            <field name="location_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="الملاحظات">
                        <field name="notes" nolabel="1"
                               placeholder="أي ملاحظات عن هذه العيادة أو القسم..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_medical_location_list" model="ir.ui.view">
        <field name="name">medical.location.list</field>
        <field name="model">medical.location</field>
        <field name="arch" type="xml">
            <list string="العيادات والأقسام">
                <field name="name" string="الاسم"/>
                <field name="location_type" string="النوع"/>
                <field name="responsible_id" string="المسؤول"/>
                <field name="current_stock_count" string="المنتجات في المخزون"/>
                <field name="active" optional="show" string="نشط"/>
            </list>
        </field>
    </record>

    <record id="action_medical_locations" model="ir.actions.act_window">
        <field name="name">العيادات والأقسام</field>
        <field name="res_model">medical.location</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                أضف أول عيادة أو قسم
            </p>
        </field>
    </record>
</odoo>
