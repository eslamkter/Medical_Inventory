<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_medical_location_form" model="ir.ui.view">
        <field name="name">medical.location.form</field>
        <field name="model">medical.location</field>
        <field name="arch" type="xml">
            <form string="Clinic / Department">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_stock" type="object"
                                class="oe_stat_button" icon="fa-cubes"
                                invisible="not location_id">
                            <field name="current_stock_count" widget="statinfo"
                                   string="Products in Stock"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Clinic 4"/></h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="location_type"/>
                            <field name="responsible_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Linked Location">
                            <field name="location_id" readonly="1"
                                   help="This is automatically created when you save"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"
                               placeholder="Any notes about this clinic or department..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_medical_location_list" model="ir.ui.view">
        <field name="name">medical.location.list</field>
        <field name="model">medical.location</field>
        <field name="arch" type="xml">
            <list string="Clinics &amp; Departments">
                <field name="name"/>
                <field name="location_type"/>
                <field name="responsible_id"/>
                <field name="current_stock_count"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_medical_locations" model="ir.actions.act_window">
        <field name="name">Clinics &amp; Departments</field>
        <field name="res_model">medical.location</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first clinic or department
            </p>
            <p>
                Create clinics and departments here. Each one automatically
                gets its own stock location — no need to go to the Inventory module.
            </p>
        </field>
    </record>

</odoo>
