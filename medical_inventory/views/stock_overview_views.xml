<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VIEW 1: Products in stock (using stock.quant - only where qty > 0) -->
    <record id="view_medical_stock_products_list" model="ir.ui.view">
        <field name="name">medical.stock.products.list</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="Products in Stock">
                <field name="location_id" string="Location"/>
                <field name="product_id" string="Product"/>
                <field name="lot_id" string="Batch/Lot" optional="show"/>
                <field name="quantity" string="Quantity on Hand"/>
                <field name="product_uom_id" string="Unit"/>
            </list>
        </field>
    </record>

    <record id="view_medical_stock_products_search" model="ir.ui.view">
        <field name="name">medical.stock.products.search</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <search string="Search Stock">
                <field name="product_id"/>
                <field name="location_id"/>
                <separator/>
                <filter string="By Location" name="group_location"
                        context="{'group_by': 'location_id'}"/>
                <filter string="By Product" name="group_product"
                        context="{'group_by': 'product_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_medical_stock_overview" model="ir.actions.act_window">
        <field name="name">Current Stock</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_medical_stock_products_list"/>
        <field name="search_view_id" ref="view_medical_stock_products_search"/>
        <field name="domain">[('location_id.usage', '=', 'internal'), ('quantity', '&gt;', 0)]</field>
        <field name="context">{'search_default_group_location': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No stock found</p>
            <p>Use Receive Stock to add items to your inventory.</p>
        </field>
    </record>

    <!-- VIEW 2: All locations overview including empty ones -->
    <record id="view_medical_locations_stock_list" model="ir.ui.view">
        <field name="name">medical.locations.stock.list</field>
        <field name="model">medical.location</field>
        <field name="arch" type="xml">
            <list string="All Locations">
                <field name="name" string="Clinic / Department"/>
                <field name="location_type" string="Type"/>
                <field name="responsible_id" string="Responsible"/>
                <field name="current_stock_count" string="Products in Stock"/>
            </list>
        </field>
    </record>

    <record id="action_medical_locations_stock" model="ir.actions.act_window">
        <field name="name">All Locations</field>
        <field name="res_model">medical.location</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_medical_locations_stock_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No locations found</p>
            <p>Add clinics and departments from Configuration menu.</p>
        </field>
    </record>

</odoo>
