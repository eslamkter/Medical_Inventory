<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top level menu -->
    <menuitem id="menu_medical_inventory_root"
              name="Medical Inventory"
              sequence="50"
              web_icon="medical_inventory,static/description/icon.png"/>

    <!-- Consumption Requests -->
    <menuitem id="menu_consumption_requests"
              name="Consumption Requests"
              parent="menu_medical_inventory_root"
              sequence="10"/>

    <menuitem id="menu_consumption_request_all"
              name="All Requests"
              parent="menu_consumption_requests"
              action="action_consumption_request"
              sequence="10"/>

    <!-- Stock Monitoring -->
    <menuitem id="menu_stock_monitoring"
              name="Stock Monitoring"
              parent="menu_medical_inventory_root"
              sequence="20"/>

    <menuitem id="menu_low_stock_alerts"
              name="Low Stock Alert Rules"
              parent="menu_stock_monitoring"
              action="action_stock_alerts"
              sequence="10"/>

    <menuitem id="menu_expiry_tracker"
              name="Expiry Tracker"
              parent="menu_stock_monitoring"
              action="action_expiry_tracker"
              sequence="20"/>

</odoo>
