<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_medical_inventory_root"
              name="Medical Inventory"
              sequence="50"/>

    <!-- Current Stock - products with qty > 0, grouped by location -->
    <menuitem id="menu_stock_overview"
              name="Current Stock"
              parent="menu_medical_inventory_root"
              action="action_medical_stock_overview"
              sequence="5"/>

    <!-- All Locations - shows every location even if empty -->
    <menuitem id="menu_all_locations_stock"
              name="All Locations"
              parent="menu_medical_inventory_root"
              action="action_medical_locations_stock"
              sequence="7"/>

    <!-- Receive Stock -->
    <menuitem id="menu_stock_receive"
              name="Receive Stock"
              parent="menu_medical_inventory_root"
              action="action_stock_receive"
              sequence="10"/>

    <!-- Consumption Requests -->
    <menuitem id="menu_consumption_requests"
              name="Consumption Requests"
              parent="menu_medical_inventory_root"
              sequence="20"/>

    <menuitem id="menu_consumption_request_all"
              name="All Requests"
              parent="menu_consumption_requests"
              action="action_consumption_request"
              sequence="10"/>

    <!-- Stock Monitoring -->
    <menuitem id="menu_stock_monitoring"
              name="Stock Monitoring"
              parent="menu_medical_inventory_root"
              sequence="30"/>

    <menuitem id="menu_low_stock_alerts"
              name="Low Stock Alert Rules"
              parent="menu_stock_monitoring"
              action="action_stock_alerts"
              sequence="10"/>

    <menuitem id="menu_expiry_tracker"
              name="Expiry Tracker"
              parent="menu_stock_monitoring"
              action="action_expiry_tracker"
              sequence="20"/>

    <!-- Configuration -->
    <menuitem id="menu_medical_config"
              name="Configuration"
              parent="menu_medical_inventory_root"
              sequence="100"/>

    <menuitem id="menu_medical_locations"
              name="Clinics &amp; Departments"
              parent="menu_medical_config"
              action="action_medical_locations"
              sequence="10"/>

</odoo>
