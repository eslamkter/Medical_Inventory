<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_alert_list" model="ir.ui.view">
        <field name="name">medical.stock.alert.list</field>
        <field name="model">medical.stock.alert</field>
        <field name="arch" type="xml">
            <list string="Low Stock Alert Rules"
                  decoration-danger="is_below_minimum == True">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="minimum_qty"/>
                <field name="current_qty"/>
                <field name="is_below_minimum" widget="boolean" string="Below Minimum?"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_stock_alert_form" model="ir.ui.view">
        <field name="name">medical.stock.alert.form</field>
        <field name="model">medical.stock.alert</field>
        <field name="arch" type="xml">
            <form string="Low Stock Alert Rule">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="location_id"/>
                        <field name="minimum_qty"/>
                        <field name="current_qty" readonly="1"/>
                        <field name="is_below_minimum" readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_stock_alerts" model="ir.actions.act_window">
        <field name="name">Low Stock Alerts</field>
        <field name="res_model">medical.stock.alert</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set up your first stock alert rule
            </p>
            <p>
                Define minimum quantities per product per clinic.
                Items below the minimum are highlighted in red.
            </p>
        </field>
    </record>

</odoo>
