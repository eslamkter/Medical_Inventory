<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_analytics_report_form" model="ir.ui.view">
        <field name="name">medical.analytics.report.form</field>
        <field name="model">medical.analytics.report</field>
        <field name="arch" type="xml">
            <form string="إنشاء تقرير">
                <sheet>
                    <div class="oe_title">
                        <h2>📊 إنشاء تقرير تحليلي</h2>
                    </div>
                    <group>
                        <group string="إعدادات التقرير">
                            <field name="report_type" widget="radio" string="نوع التقرير"/>
                            <field name="export_format" widget="radio" string="الصيغة"/>
                        </group>
                        <group string="الفلاتر">
                            <field name="date_from" string="من تاريخ"/>
                            <field name="date_to" string="إلى تاريخ"/>
                            <field name="location_id" string="الموقع"/>
                            <field name="product_id" string="المنتج"/>
                        </group>
                    </group>
                    <div invisible="state != 'done'" class="alert alert-success" role="alert">
                        <strong>✅ التقرير جاهز!</strong> انقر على زر التحميل أدناه.
                    </div>
                    <group invisible="state != 'done'">
                        <field name="file_data" filename="file_name" widget="binary"
                               string="تحميل التقرير"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <footer>
                        <button name="action_generate" string="إنشاء التقرير"
                                type="object" class="btn-primary"
                                invisible="state == 'done'"/>
                        <button name="action_generate" string="إعادة إنشاء"
                                type="object" class="btn-secondary"
                                invisible="state != 'done'"/>
                        <button string="إغلاق" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_analytics_report_wizard" model="ir.actions.act_window">
        <field name="name">إنشاء تقرير (Excel/PDF)</field>
        <field name="res_model">medical.analytics.report</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_analytics_report_form"/>
        <field name="target">new</field>
    </record>
</odoo>
