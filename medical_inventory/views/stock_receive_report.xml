<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- قالب الطباعة HTML -->
    <template id="report_stock_receive_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; direction: rtl;">

                        <div style="text-align:center; margin-bottom:20px; border-bottom:2px solid #1565c0; padding-bottom:10px;">
                            <h2 style="color:#1565c0; margin:0;">🏥 إيصال استلام مخزون</h2>
                            <h3 style="margin:5px 0;"><t t-esc="o.name"/></h3>
                        </div>

                        <div style="display:flex; justify-content:space-between; margin-bottom:20px; gap:20px;">
                            <div style="flex:1; background:#f8fafc; padding:12px; border-radius:6px;">
                                <table style="width:100%; border-collapse:collapse;">
                                    <tr>
                                        <td style="padding:4px 8px; font-weight:bold; color:#64748b;">التاريخ:</td>
                                        <td style="padding:4px 8px;"><t t-esc="o.date_receive"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:4px 8px; font-weight:bold; color:#64748b;">استلم بواسطة:</td>
                                        <td style="padding:4px 8px;"><t t-esc="o.received_by.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:4px 8px; font-weight:bold; color:#64748b;">موقع التخزين:</td>
                                        <td style="padding:4px 8px;"><t t-esc="o.destination_location_id.name"/></td>
                                    </tr>
                                    <t t-if="o.vendor_invoice_ref">
                                        <tr>
                                            <td style="padding:4px 8px; font-weight:bold; color:#64748b;">مرجع الفاتورة:</td>
                                            <td style="padding:4px 8px;"><t t-esc="o.vendor_invoice_ref"/></td>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                            <div style="flex:1; background:#f8fafc; padding:12px; border-radius:6px;">
                                <table style="width:100%; border-collapse:collapse;">
                                    <tr>
                                        <td style="padding:4px 8px; font-weight:bold; color:#64748b;">المورد:</td>
                                        <td style="padding:4px 8px; font-weight:bold;">
                                            <t t-esc="o.vendor_id.name or o.vendor_name or '—'"/>
                                        </td>
                                    </tr>
                                    <t t-if="o.vendor_id">
                                        <tr>
                                            <td style="padding:4px 8px; font-weight:bold; color:#64748b;">الرصيد القديم:</td>
                                            <td style="padding:4px 8px; color:#0369a1;">
                                                <t t-esc="'%.2f EGP' % o.vendor_old_balance"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding:4px 8px; font-weight:bold; color:#64748b;">قيمة هذا الاستلام:</td>
                                            <td style="padding:4px 8px; color:#1565c0;">
                                                + <t t-esc="'%.2f EGP' % o.total_value"/>
                                            </td>
                                        </tr>
                                        <t t-if="o.amount_paid > 0">
                                            <tr>
                                                <td style="padding:4px 8px; font-weight:bold; color:#64748b;">المدفوع الآن:</td>
                                                <td style="padding:4px 8px; color:#15803d;">
                                                    - <t t-esc="'%.2f EGP' % o.amount_paid"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <tr style="border-top:2px solid #1565c0;">
                                            <td style="padding:6px 8px; font-weight:bold; color:#64748b;">الرصيد الجديد:</td>
                                            <td style="padding:6px 8px; font-weight:bold; font-size:16px; color:#c2410c;">
                                                <t t-esc="'%.2f EGP' % o.vendor_new_balance"/>
                                            </td>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                        </div>

                        <table style="width:100%; border-collapse:collapse; margin-bottom:20px;">
                            <thead>
                                <tr style="background:#1565c0; color:white;">
                                    <th style="padding:10px; text-align:right; border:1px solid #1565c0;">#</th>
                                    <th style="padding:10px; text-align:right; border:1px solid #1565c0;">المنتج</th>
                                    <th style="padding:10px; text-align:center; border:1px solid #1565c0;">الكمية</th>
                                    <th style="padding:10px; text-align:center; border:1px solid #1565c0;">الوحدة</th>
                                    <th style="padding:10px; text-align:center; border:1px solid #1565c0;">سعر الوحدة</th>
                                    <th style="padding:10px; text-align:center; border:1px solid #1565c0;">الإجمالي</th>
                                    <th style="padding:10px; text-align:center; border:1px solid #1565c0;">تاريخ الانتهاء</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr t-attf-style="background:#{line_index % 2 == 0 and '#f8fafc' or 'white'}">
                                        <td style="padding:8px; border:1px solid #e2e8f0; text-align:center;"><t t-esc="line_index + 1"/></td>
                                        <td style="padding:8px; border:1px solid #e2e8f0; font-weight:bold;"><t t-esc="line.product_id.name"/></td>
                                        <td style="padding:8px; border:1px solid #e2e8f0; text-align:center;"><t t-esc="line.quantity"/></td>
                                        <td style="padding:8px; border:1px solid #e2e8f0; text-align:center;"><t t-esc="line.product_uom_id.name"/></td>
                                        <td style="padding:8px; border:1px solid #e2e8f0; text-align:center;"><t t-esc="'%.2f' % line.unit_price"/></td>
                                        <td style="padding:8px; border:1px solid #e2e8f0; text-align:center; font-weight:bold;"><t t-esc="'%.2f' % line.subtotal"/></td>
                                        <td style="padding:8px; border:1px solid #e2e8f0; text-align:center;"><t t-esc="line.expiry_date or '—'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background:#1e293b; color:white; font-weight:bold;">
                                    <td colspan="5" style="padding:10px; border:1px solid #1e293b;">الإجمالي الكلي</td>
                                    <td style="padding:10px; border:1px solid #1e293b; text-align:center; font-size:16px;">
                                        <t t-esc="'%.2f EGP' % o.total_value"/>
                                    </td>
                                    <td style="border:1px solid #1e293b;"></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div style="display:flex; justify-content:flex-end; margin-bottom:20px;">
                            <div style="min-width:300px; border:1px solid #e2e8f0; border-radius:6px; overflow:hidden;">
                                <div style="background:#f1f5f9; padding:8px 12px; font-weight:bold; border-bottom:1px solid #e2e8f0;">ملخص الدفع</div>
                                <table style="width:100%; border-collapse:collapse;">
                                    <tr>
                                        <td style="padding:8px 12px; color:#64748b;">قيمة الفاتورة:</td>
                                        <td style="padding:8px 12px; text-align:left; font-weight:bold;"><t t-esc="'%.2f EGP' % o.total_value"/></td>
                                    </tr>
                                    <tr style="background:#f8fafc;">
                                        <td style="padding:8px 12px; color:#64748b;">المدفوع الآن:</td>
                                        <td style="padding:8px 12px; text-align:left; color:#15803d; font-weight:bold;"><t t-esc="'%.2f EGP' % o.amount_paid"/></td>
                                    </tr>
                                    <tr style="border-top:2px solid #e2e8f0;">
                                        <td style="padding:10px 12px; font-weight:bold;">المتبقي:</td>
                                        <td style="padding:10px 12px; text-align:left; font-weight:bold; color:#c2410c; font-size:15px;"><t t-esc="'%.2f EGP' % o.amount_due"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div style="display:flex; justify-content:space-between; margin-top:40px; padding-top:20px; border-top:1px solid #e2e8f0;">
                            <div style="text-align:center; width:30%;">
                                <div style="border-top:1px solid #333; padding-top:5px; margin-top:30px;">توقيع المستلم</div>
                            </div>
                            <div style="text-align:center; width:30%;">
                                <div style="border-top:1px solid #333; padding-top:5px; margin-top:30px;">توقيع المورد</div>
                            </div>
                            <div style="text-align:center; width:30%;">
                                <div style="border-top:1px solid #333; padding-top:5px; margin-top:30px;">توقيع المدير</div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report as HTML (works without wkhtmltopdf) -->
    <record id="action_report_stock_receive" model="ir.actions.report">
        <field name="name">إيصال الاستلام</field>
        <field name="model">medical.stock.receive</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">medical_inventory.report_stock_receive_template</field>
        <field name="report_file">medical_inventory.report_stock_receive_template</field>
        <field name="binding_model_id" ref="model_medical_stock_receive"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
