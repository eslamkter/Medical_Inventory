<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_card_list" model="ir.ui.view">
        <field name="name">medical.stock.card.list</field>
        <field name="model">medical.stock.card</field>
        <field name="arch" type="xml">
            <list string="كارتة الصنف" create="0" edit="0" delete="0"
                  decoration-success="move_type == 'in'"
                  decoration-danger="move_type == 'out'">
                <field name="date" string="التاريخ"/>
                <field name="move_type" string="النوع" widget="badge"
                       decoration-success="move_type == 'in'"
                       decoration-danger="move_type == 'out'"/>
                <field name="reference" string="المرجع"/>
                <field name="source" string="المصدر / الوجهة"/>
                <field name="quantity" string="الكمية"/>
                <field name="uom" string="الوحدة"/>
                <field name="unit_price" string="سعر الوحدة"
                       invisible="move_type == 'out'"/>
                <field name="total_value" string="القيمة"
                       invisible="move_type == 'out'"/>
                <field name="balance_qty" string="رصيد الكمية"/>
                <field name="vendor_id" string="المورد" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_stock_card_search" model="ir.ui.view">
        <field name="name">medical.stock.card.search</field>
        <field name="model">medical.stock.card</field>
        <field name="arch" type="xml">
            <search string="بحث في كارتة الصنف">
                <field name="product_id" string="المنتج"/>
                <field name="vendor_id" string="المورد"/>
                <field name="location_id" string="الموقع"/>
                <filter string="وارد فقط" name="in_only"
                        domain="[('move_type', '=', 'in')]"/>
                <filter string="صادر فقط" name="out_only"
                        domain="[('move_type', '=', 'out')]"/>
                <filter string="هذا الشهر" name="this_month"
                        domain="[('date', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter string="حسب المنتج" name="group_product"
                        context="{'group_by': 'product_id'}"/>
                <filter string="حسب الموقع" name="group_location"
                        context="{'group_by': 'location_id'}"/>
                <filter string="حسب الشهر" name="group_month"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_stock_card" model="ir.actions.act_window">
        <field name="name">كارتة الصنف</field>
        <field name="res_model">medical.stock.card</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_stock_card_search"/>
        <field name="context">{'search_default_group_product': 1}</field>
    </record>

</odoo>
